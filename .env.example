REDLINE_SERVICE_ENV=local
REDLINE_SERVICE_ROOT=artifacts/service
REDLINE_SERVICE_TOKEN=redline-demo
# Optional production RBAC token registry. When set, this JSON replaces the
# single REDLINE_SERVICE_TOKEN identity while preserving token auth headers.
# [{"token":"<32+ chars>","principal_id":"reviewer-1","role":"reviewer","scopes":["read-only","release-write"]}]
REDLINE_SERVICE_TOKENS=
REDLINE_AUTH_SESSION_SECRET=
REDLINE_AUTH_USERS=
REDLINE_DEV_AUTH_ENABLED=0
REDLINE_DEV_AUTH_USER=
REDLINE_GITHUB_OAUTH_CLIENT_ID=
REDLINE_GITHUB_OAUTH_CLIENT_SECRET=
REDLINE_GITHUB_OAUTH_REDIRECT_URI=
REDLINE_AUTH_ALLOWED_GITHUB_LOGINS=
REDLINE_SERVICE_HOST=127.0.0.1
REDLINE_SERVICE_PORT=8080
REDLINE_SERVICE_CORS_ORIGINS=http://localhost:3000
REDLINE_SERVICE_MAX_UPLOAD_BYTES=52428800
REDLINE_SERVICE_WORKERS=2
REDLINE_SERVICE_LOG_LEVEL=INFO
REDLINE_SERVICE_METADATA_STORE=sqlite
REDLINE_SERVICE_ARTIFACT_STORE=local
REDLINE_SERVICE_EXPOSE_ERROR_DETAILS=true
REDLINE_DATABASE_URL=
REDLINE_SERVICE_RATE_LIMIT_PER_MINUTE=120
REDLINE_SERVICE_MAX_PACKAGES=100
REDLINE_SERVICE_MAX_ACTIVE_RUNS=8
REDLINE_SERVICE_MAX_RUNS_TOTAL=500
REDLINE_SERVICE_RUN_RETENTION_SECONDS=604800

# Production must override REDLINE_SERVICE_TOKEN with a non-default 32+ character value.
# Live sponsor mode also needs REDLINE_BITGET_ACCESS_KEY, REDLINE_BITGET_SECRET_KEY,
# and REDLINE_BITGET_PASSPHRASE.

# Demo execution gate credentials are separate from live sponsor/publish credentials.
REDLINE_BITGET_DEMO_ACCESS_KEY=
REDLINE_BITGET_DEMO_SECRET_KEY=
REDLINE_BITGET_DEMO_PASSPHRASE=
REDLINE_BITGET_PAPTRADING=1
REDLINE_BITGET_BASE_URL=https://api.bitget.com
REDLINE_BITGET_DEMO_SYMBOL=BTCUSDT
REDLINE_BITGET_DEMO_SIZE=0.0001
REDLINE_BITGET_PRODUCT_TYPE=USDT-FUTURES
# Release-level safety controls.
REDLINE_RELEASE_FREEZE=0
REDLINE_EXECUTION_FREEZE=0
# Mainnet order placement stays blocked unless this is set to 1 and the
# /execute request also sends confirm_mainnet_order=true.
REDLINE_ALLOW_MAINNET_ORDER=
