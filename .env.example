REDLINE_SERVICE_ENV=local
REDLINE_SERVICE_ROOT=artifacts/service
REDLINE_SERVICE_TOKEN=redline-demo
REDLINE_SERVICE_HOST=127.0.0.1
REDLINE_SERVICE_PORT=8080
REDLINE_SERVICE_CORS_ORIGINS=http://localhost:3000
REDLINE_SERVICE_MAX_UPLOAD_BYTES=52428800
REDLINE_SERVICE_WORKERS=2
REDLINE_SERVICE_LOG_LEVEL=INFO
REDLINE_SERVICE_METADATA_STORE=sqlite
REDLINE_SERVICE_ARTIFACT_STORE=local
REDLINE_SERVICE_EXPOSE_ERROR_DETAILS=true
REDLINE_DATABASE_URL=
REDLINE_SERVICE_RATE_LIMIT_PER_MINUTE=120
REDLINE_SERVICE_MAX_PACKAGES=100
REDLINE_SERVICE_MAX_ACTIVE_RUNS=8
REDLINE_SERVICE_MAX_RUNS_TOTAL=500
REDLINE_SERVICE_RUN_RETENTION_SECONDS=604800

# Production must override REDLINE_SERVICE_TOKEN with a non-default 32+ character value.
# Live sponsor mode also needs REDLINE_BITGET_ACCESS_KEY, REDLINE_BITGET_SECRET_KEY,
# and REDLINE_BITGET_PASSPHRASE.
