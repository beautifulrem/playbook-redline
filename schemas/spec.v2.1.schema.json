{
  "$defs": {
    "ProbeSpec": {
      "additionalProperties": false,
      "properties": {
        "block": {
          "default": true,
          "title": "Block",
          "type": "boolean"
        },
        "id": {
          "title": "Id",
          "type": "string"
        },
        "params": {
          "additionalProperties": {
            "type": "string"
          },
          "title": "Params",
          "type": "object"
        },
        "type": {
          "$ref": "#/$defs/ProbeType"
        }
      },
      "required": [
        "id",
        "type",
        "params"
      ],
      "title": "ProbeSpec",
      "type": "object"
    },
    "ProbeType": {
      "enum": [
        "max_drawdown",
        "no_entry_when",
        "trade_budget"
      ],
      "title": "ProbeType",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "compiler": {
      "default": "json",
      "title": "Compiler",
      "type": "string"
    },
    "declared_intent": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Declared Intent"
    },
    "degraded_reason": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Degraded Reason"
    },
    "model": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Model"
    },
    "probes": {
      "contains": {
        "anyOf": [
          {
            "not": {
              "required": [
                "block"
              ]
            }
          },
          {
            "properties": {
              "block": {
                "const": true
              }
            },
            "required": [
              "block"
            ]
          }
        ]
      },
      "items": {
        "$ref": "#/$defs/ProbeSpec"
      },
      "minItems": 1,
      "title": "Probes",
      "type": "array",
      "x-unique-by": "id"
    },
    "spec_id": {
      "title": "Spec Id",
      "type": "string"
    },
    "tool_schema_hash": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Tool Schema Hash"
    },
    "version": {
      "const": "redline.spec.v2.1",
      "default": "redline.spec.v2.1",
      "title": "Version",
      "type": "string"
    }
  },
  "required": [
    "spec_id",
    "probes"
  ],
  "title": "RedlineSpec",
  "type": "object"
}