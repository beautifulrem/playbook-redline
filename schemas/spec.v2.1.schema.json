{
  "$defs": {
    "ProbeSpec": {
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "type": {
                "const": "max_drawdown"
              }
            },
            "required": [
              "type"
            ]
          },
          "then": {
            "properties": {
              "params": {
                "additionalProperties": {
                  "type": "string"
                },
                "properties": {
                  "max_drawdown": {
                    "description": "Finite decimal string in (0, 1].",
                    "pattern": "^(?:(?:0?\\.[0-9]*[1-9][0-9]*)|(?:1(?:\\.0*)?))$",
                    "type": "string"
                  }
                },
                "required": [
                  "max_drawdown"
                ],
                "type": "object"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "no_entry_when"
              }
            },
            "required": [
              "type"
            ]
          },
          "then": {
            "properties": {
              "params": {
                "additionalProperties": {
                  "type": "string"
                },
                "anyOf": [
                  {
                    "required": [
                      "before_bar"
                    ]
                  },
                  {
                    "required": [
                      "bar_lt"
                    ]
                  }
                ],
                "properties": {
                  "bar_lt": {
                    "description": "Integer decimal string in [0, 100000].",
                    "pattern": "^0*(?:[0-9]{1,5}|100000)$",
                    "type": "string"
                  },
                  "before_bar": {
                    "description": "Integer decimal string in [0, 100000].",
                    "pattern": "^0*(?:[0-9]{1,5}|100000)$",
                    "type": "string"
                  },
                  "max_abs_position": {
                    "description": "Finite decimal string in [0, 1].",
                    "pattern": "^(?:(?:0(?:\\.[0-9]*)?)|(?:0?\\.[0-9]+)|(?:1(?:\\.0*)?))$",
                    "type": "string"
                  },
                  "scenario_id": {
                    "minLength": 1,
                    "pattern": "\\S",
                    "type": "string"
                  }
                },
                "required": [
                  "scenario_id",
                  "max_abs_position"
                ],
                "type": "object"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "trade_budget"
              }
            },
            "required": [
              "type"
            ]
          },
          "then": {
            "properties": {
              "params": {
                "additionalProperties": {
                  "type": "string"
                },
                "properties": {
                  "max_trades": {
                    "description": "Integer decimal string in [0, 1000].",
                    "pattern": "^0*(?:[0-9]{1,3}|1000)$",
                    "type": "string"
                  }
                },
                "required": [
                  "max_trades"
                ],
                "type": "object"
              }
            }
          }
        }
      ],
      "properties": {
        "block": {
          "default": true,
          "title": "Block",
          "type": "boolean"
        },
        "id": {
          "title": "Id",
          "type": "string"
        },
        "params": {
          "additionalProperties": {
            "type": "string"
          },
          "title": "Params",
          "type": "object"
        },
        "type": {
          "$ref": "#/$defs/ProbeType"
        }
      },
      "required": [
        "id",
        "type",
        "params"
      ],
      "title": "ProbeSpec",
      "type": "object",
      "x-runtime-constraints": [
        {
          "enforced_by": "redline.models.ProbeSpec.require_semantic_params",
          "name": "probe_param_semantics"
        }
      ]
    },
    "ProbeType": {
      "enum": [
        "max_drawdown",
        "no_entry_when",
        "trade_budget"
      ],
      "title": "ProbeType",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "compiler": {
      "default": "json",
      "title": "Compiler",
      "type": "string"
    },
    "declared_intent": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Declared Intent"
    },
    "degraded_reason": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Degraded Reason"
    },
    "model": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Model"
    },
    "probes": {
      "contains": {
        "anyOf": [
          {
            "not": {
              "required": [
                "block"
              ]
            }
          },
          {
            "properties": {
              "block": {
                "const": true
              }
            },
            "required": [
              "block"
            ]
          }
        ]
      },
      "items": {
        "$ref": "#/$defs/ProbeSpec"
      },
      "minItems": 1,
      "title": "Probes",
      "type": "array",
      "x-runtime-constraints": [
        {
          "enforced_by": "redline.models.RedlineSpec.require_block_probe",
          "name": "unique_probe_ids"
        }
      ],
      "x-unique-by": "id"
    },
    "spec_id": {
      "title": "Spec Id",
      "type": "string"
    },
    "tool_schema_hash": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Tool Schema Hash"
    },
    "version": {
      "const": "redline.spec.v2.1",
      "default": "redline.spec.v2.1",
      "title": "Version",
      "type": "string"
    }
  },
  "required": [
    "spec_id",
    "probes"
  ],
  "title": "RedlineSpec",
  "type": "object"
}