{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://redline.local/schemas/release-evidence-manifest.v1.schema.json",
  "title": "Redline Release Evidence Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "release_id", "generated_at", "files"],
  "properties": {
    "schema_version": {
      "const": "redline.release.evidence_manifest.v1"
    },
    "release_id": {
      "type": "string",
      "minLength": 1
    },
    "generated_at": {
      "type": "string"
    },
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "kind", "sha256", "bytes"],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string",
            "minLength": 1
          },
          "sha256": {
            "type": "string",
            "pattern": "^sha256:[0-9a-f]{64}$"
          },
          "bytes": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    }
  }
}
