{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://redline.local/schemas/release-evidence-bundle.v1.schema.json",
  "title": "Redline Release Evidence Bundle",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "release_candidate",
    "strategy_version",
    "redline",
    "simulation_evidence",
    "risk_policy",
    "execution_evidence",
    "release_decision_record",
    "audit_log_slice"
  ],
  "properties": {
    "schema_version": {
      "const": "redline.release.evidence_bundle.v1"
    },
    "release_candidate": {
      "type": "object"
    },
    "strategy_version": {
      "type": "object"
    },
    "redline": {
      "type": "object",
      "required": ["run_id", "state", "reason_code", "receipt_hash", "report_hash", "artifacts"],
      "properties": {
        "run_id": {
          "type": ["string", "null"]
        },
        "state": {
          "type": ["string", "null"]
        },
        "reason_code": {
          "type": ["string", "null"]
        },
        "receipt_hash": {
          "type": ["string", "null"]
        },
        "report_hash": {
          "type": ["string", "null"]
        },
        "artifacts": {
          "type": "array",
          "items": {
            "type": "object"
          }
        }
      }
    },
    "simulation_evidence": {
      "type": ["object", "null"]
    },
    "risk_policy": {
      "type": ["object", "null"]
    },
    "execution_evidence": {
      "type": ["object", "null"]
    },
    "release_decision_record": {
      "type": "object"
    },
    "audit_log_slice": {
      "type": "array",
      "items": {
        "$ref": "release-audit-entry.v1.schema.json"
      }
    }
  }
}
