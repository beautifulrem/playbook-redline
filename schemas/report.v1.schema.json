{
  "$defs": {
    "Assertion": {
      "additionalProperties": false,
      "properties": {
        "bar": {
          "title": "Bar",
          "type": "integer"
        },
        "holds": {
          "title": "Holds",
          "type": "boolean"
        },
        "metric": {
          "title": "Metric",
          "type": "string"
        },
        "observed": {
          "title": "Observed",
          "type": "string"
        },
        "op": {
          "enum": [
            "<=",
            "<",
            ">=",
            ">",
            "=="
          ],
          "title": "Op",
          "type": "string"
        },
        "scenario_id": {
          "title": "Scenario Id",
          "type": "string"
        },
        "threshold": {
          "title": "Threshold",
          "type": "string"
        }
      },
      "required": [
        "metric",
        "op",
        "threshold",
        "observed",
        "scenario_id",
        "bar",
        "holds"
      ],
      "title": "Assertion",
      "type": "object"
    },
    "Capabilities": {
      "additionalProperties": false,
      "properties": {
        "engine": {
          "$ref": "#/$defs/Capability"
        },
        "llm_in_verdict": {
          "default": false,
          "title": "Llm In Verdict",
          "type": "boolean"
        },
        "qwen_compile": {
          "$ref": "#/$defs/Capability"
        },
        "scenario_count": {
          "default": 0,
          "title": "Scenario Count",
          "type": "integer"
        },
        "sponsor_readback": {
          "$ref": "#/$defs/Capability"
        }
      },
      "title": "Capabilities",
      "type": "object"
    },
    "Capability": {
      "additionalProperties": false,
      "properties": {
        "degraded": {
          "default": false,
          "title": "Degraded",
          "type": "boolean"
        },
        "mode": {
          "title": "Mode",
          "type": "string"
        },
        "reason": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Reason"
        }
      },
      "required": [
        "mode"
      ],
      "title": "Capability",
      "type": "object"
    },
    "ChainStatus": {
      "enum": [
        "chained",
        "genesis",
        "unchained"
      ],
      "title": "ChainStatus",
      "type": "string"
    },
    "CoverageManifest": {
      "additionalProperties": false,
      "properties": {
        "cells": {
          "items": {
            "maxItems": 2,
            "minItems": 2,
            "prefixItems": [
              {
                "type": "string"
              },
              {
                "type": "string"
              }
            ],
            "type": "array"
          },
          "title": "Cells",
          "type": "array"
        },
        "complete": {
          "title": "Complete",
          "type": "boolean"
        },
        "manifest": {
          "default": "suite.scenarios\u00d7spec.block_probes",
          "title": "Manifest",
          "type": "string"
        },
        "missing": {
          "items": {
            "type": "string"
          },
          "title": "Missing",
          "type": "array"
        }
      },
      "required": [
        "cells",
        "complete"
      ],
      "title": "CoverageManifest",
      "type": "object"
    },
    "DecisionEnvelope": {
      "additionalProperties": false,
      "properties": {
        "adjusted_size_cap": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Adjusted Size Cap"
        },
        "capabilities": {
          "$ref": "#/$defs/Capabilities"
        },
        "chain_status": {
          "$ref": "#/$defs/ChainStatus"
        },
        "coverage": {
          "$ref": "#/$defs/CoverageManifest"
        },
        "envelope_version": {
          "const": "redline.decision.v1",
          "default": "redline.decision.v1",
          "title": "Envelope Version",
          "type": "string"
        },
        "reason_code": {
          "$ref": "#/$defs/ReasonCode"
        },
        "required_proof_ids": {
          "items": {
            "type": "string"
          },
          "title": "Required Proof Ids",
          "type": "array"
        },
        "satisfied_proof_ids": {
          "items": {
            "type": "string"
          },
          "title": "Satisfied Proof Ids",
          "type": "array"
        },
        "status": {
          "$ref": "#/$defs/Status"
        },
        "verdict_tier": {
          "anyOf": [
            {
              "$ref": "#/$defs/VerdictTier"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "status",
        "reason_code",
        "chain_status",
        "required_proof_ids",
        "satisfied_proof_ids",
        "coverage",
        "capabilities"
      ],
      "title": "DecisionEnvelope",
      "type": "object"
    },
    "EditProvenance": {
      "additionalProperties": false,
      "properties": {
        "captured_at": {
          "title": "Captured At",
          "type": "string"
        },
        "diff_hash": {
          "title": "Diff Hash",
          "type": "string"
        },
        "locked_by": {
          "default": "author",
          "title": "Locked By",
          "type": "string"
        },
        "prompt_digest": {
          "title": "Prompt Digest",
          "type": "string"
        },
        "tool": {
          "default": "fixture",
          "title": "Tool",
          "type": "string"
        }
      },
      "required": [
        "prompt_digest",
        "diff_hash",
        "captured_at"
      ],
      "title": "EditProvenance",
      "type": "object"
    },
    "Proof": {
      "additionalProperties": false,
      "properties": {
        "artifact_hash": {
          "title": "Artifact Hash",
          "type": "string"
        },
        "assertions": {
          "items": {
            "$ref": "#/$defs/Assertion"
          },
          "title": "Assertions",
          "type": "array"
        },
        "fees_modeled": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Fees Modeled"
        },
        "fill_model": {
          "anyOf": [
            {
              "const": "next_bar_open",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Fill Model"
        },
        "inputs_hash": {
          "title": "Inputs Hash",
          "type": "string"
        },
        "kind": {
          "$ref": "#/$defs/ProofKind"
        },
        "lookahead_guard": {
          "anyOf": [
            {
              "const": "structural_next_bar",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Lookahead Guard"
        },
        "meta": {
          "additionalProperties": true,
          "title": "Meta",
          "type": "object"
        },
        "phase": {
          "title": "Phase",
          "type": "string"
        },
        "proof_id": {
          "title": "Proof Id",
          "type": "string"
        },
        "reproduce": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Reproduce"
        },
        "verdict_bearing": {
          "title": "Verdict Bearing",
          "type": "boolean"
        }
      },
      "required": [
        "proof_id",
        "phase",
        "kind",
        "verdict_bearing",
        "inputs_hash",
        "artifact_hash"
      ],
      "title": "Proof",
      "type": "object"
    },
    "ProofKind": {
      "enum": [
        "package_canonical",
        "edit_provenance",
        "spec_compile",
        "baseline_calibration",
        "replay",
        "replay_wellformed",
        "probe",
        "coverage",
        "candidate_absolute",
        "decision",
        "sponsor_readback",
        "verification"
      ],
      "title": "ProofKind",
      "type": "string"
    },
    "PublishInfo": {
      "additionalProperties": false,
      "properties": {
        "attempted": {
          "default": false,
          "title": "Attempted",
          "type": "boolean"
        },
        "note": {
          "default": "run_id is platform execution evidence, not local-equivalence proof",
          "title": "Note",
          "type": "string"
        },
        "readback_hash": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Readback Hash"
        },
        "run_evidence_hash": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Run Evidence Hash"
        },
        "run_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Run Id"
        },
        "sponsor_status": {
          "default": "not_attempted",
          "title": "Sponsor Status",
          "type": "string"
        },
        "stop_before_final_publish": {
          "default": true,
          "title": "Stop Before Final Publish",
          "type": "boolean"
        },
        "version_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Version Id"
        }
      },
      "title": "PublishInfo",
      "type": "object"
    },
    "ReasonCode": {
      "enum": [
        "PASS",
        "NEW_BLOCK_BREACH",
        "RECEIPT_MISMATCH",
        "PROOF_HASH_MISMATCH",
        "LEDGER_CHAIN_BROKEN",
        "CHECKPOINT_MISMATCH",
        "EXECUTION_LEDGER_BROKEN",
        "MERKLE_INCLUSION_FAILED",
        "APPROVAL_LINK_MISMATCH",
        "APPROVAL_CONSUMED",
        "APPROVAL_EXPIRED",
        "CHAIN_LINK_MISMATCH",
        "BASELINE_UNCHAINED",
        "BASELINE_GENESIS",
        "COVERAGE_INCOMPLETE",
        "PROBE_ERROR",
        "ENGINE_FAILURE",
        "DATA_MISSING",
        "CALIBRATION_FAILED",
        "BASELINE_BREACHES",
        "BASELINE_UNRUNNABLE",
        "NONFINITE_VALUE",
        "ENGINE_IDENTITY_MISMATCH",
        "CANDIDATE_SANDBOX_VIOLATION",
        "VERDICT_PATH_VIOLATION",
        "RECEIPT_BINDING_FAILED",
        "SPONSOR_READBACK_MISMATCH",
        "SPONSOR_EVIDENCE_UNVERIFIED",
        "UNVERIFIED_NO_VERDICT",
        "FILE_NOT_FOUND",
        "PARSE_ERROR",
        "SCHEMA_INVALID",
        "VERSION_UNSUPPORTED",
        "OUT_OF_SCOPE"
      ],
      "title": "ReasonCode",
      "type": "string"
    },
    "ReplayPoint": {
      "additionalProperties": false,
      "properties": {
        "bar": {
          "title": "Bar",
          "type": "integer"
        },
        "close": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Close"
        },
        "drawdown": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Drawdown"
        },
        "nav": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Nav"
        },
        "peak": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Peak"
        },
        "position": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Position"
        },
        "timestamp": {
          "title": "Timestamp",
          "type": "string"
        }
      },
      "required": [
        "bar",
        "timestamp",
        "close",
        "nav",
        "peak",
        "drawdown",
        "position"
      ],
      "title": "ReplayPoint",
      "type": "object"
    },
    "ReplayTrace": {
      "additionalProperties": false,
      "properties": {
        "artifact_hash": {
          "title": "Artifact Hash",
          "type": "string"
        },
        "bars": {
          "title": "Bars",
          "type": "integer"
        },
        "engine": {
          "default": "deterministic",
          "enum": [
            "deterministic",
            "nautilus"
          ],
          "title": "Engine",
          "type": "string"
        },
        "input_hash": {
          "title": "Input Hash",
          "type": "string"
        },
        "points": {
          "items": {
            "$ref": "#/$defs/ReplayPoint"
          },
          "title": "Points",
          "type": "array"
        },
        "role": {
          "enum": [
            "baseline",
            "candidate"
          ],
          "title": "Role",
          "type": "string"
        },
        "scenario_id": {
          "title": "Scenario Id",
          "type": "string"
        },
        "trade_count": {
          "title": "Trade Count",
          "type": "integer"
        }
      },
      "required": [
        "scenario_id",
        "role",
        "bars",
        "trade_count",
        "points",
        "input_hash",
        "artifact_hash"
      ],
      "title": "ReplayTrace",
      "type": "object"
    },
    "Status": {
      "enum": [
        "pass",
        "withheld",
        "reduce_size",
        "reject",
        "unverified_no_verdict"
      ],
      "title": "Status",
      "type": "string"
    },
    "VerdictTier": {
      "enum": [
        "ALLOW",
        "REDUCE_SIZE",
        "HUMAN_REVIEW",
        "BLOCK"
      ],
      "title": "VerdictTier",
      "type": "string"
    },
    "VerificationLevel": {
      "enum": [
        "hash_only",
        "replayed"
      ],
      "title": "VerificationLevel",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "coverage_missing": {
      "items": {
        "type": "string"
      },
      "title": "Coverage Missing",
      "type": "array"
    },
    "edit_provenance": {
      "anyOf": [
        {
          "$ref": "#/$defs/EditProvenance"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "envelope": {
      "$ref": "#/$defs/DecisionEnvelope"
    },
    "proof_ids": {
      "items": {
        "type": "string"
      },
      "title": "Proof Ids",
      "type": "array"
    },
    "proofs": {
      "items": {
        "$ref": "#/$defs/Proof"
      },
      "title": "Proofs",
      "type": "array"
    },
    "publish": {
      "anyOf": [
        {
          "$ref": "#/$defs/PublishInfo"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "receipt_hash": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Receipt Hash"
    },
    "report_hash": {
      "title": "Report Hash",
      "type": "string"
    },
    "strength_summary": {
      "default": "",
      "title": "Strength Summary",
      "type": "string"
    },
    "traces": {
      "items": {
        "$ref": "#/$defs/ReplayTrace"
      },
      "title": "Traces",
      "type": "array"
    },
    "verification_level": {
      "anyOf": [
        {
          "$ref": "#/$defs/VerificationLevel"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "version": {
      "const": "redline.report.v1",
      "default": "redline.report.v1",
      "title": "Version",
      "type": "string"
    }
  },
  "required": [
    "envelope",
    "traces",
    "proof_ids",
    "report_hash"
  ],
  "title": "ReportJson",
  "type": "object"
}